# =============================================================================
# SmartZap / VozzySmart - Variáveis de Ambiente
# =============================================================================
# Copie para .env.local e preencha com seus valores para teste local.
# Na Vercel: Project Settings > Environment Variables
# =============================================================================

# --- Supabase (obrigatório) ---
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SECRET_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# --- Login (obrigatório para acessar o dashboard) ---
MASTER_PASSWORD=sua_senha_segura_aqui

# --- Upstash - QStash + Redis ---
QSTASH_TOKEN=
UPSTASH_REDIS_REST_URL=https://SEU_REDIS.upstash.io
UPSTASH_REDIS_REST_TOKEN=

# --- Licenças + n8n ---
SMARTZAP_API_KEY=szap_sua_chave_api_aqui
SMARTZAP_ADMIN_KEY=szap_sua_chave_admin_aqui

# --- GitHub Fork (tela 2 do wizard) ---
GITHUB_SOURCE_REPO=seu-usuario/seu-repositorio

# --- GitHub OAuth (conectar sem token manual) ---
# Crie um OAuth App em https://github.com/settings/developers
# Authorization callback URL: https://SEU_DOMINIO/api/installer/github/oauth/callback
GITHUB_OAUTH_CLIENT_ID=sua_client_id_do_github
GITHUB_OAUTH_CLIENT_SECRET=sua_client_secret_do_github

# --- Opcional: desabilitar wizard após configurar ---
# INSTALLER_ENABLED=false

# --- App URL (para callbacks, webhooks) ---
# NEXT_PUBLIC_APP_URL=http://localhost:3000
